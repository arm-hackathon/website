# Copy to .env.local and replace every placeholder with real values.
# Never commit .env.local.

AUTH_URL=http://127.0.0.1:4321
AUTH_TRUST_HOST=true
AUTH_SECRET=replace-with-a-random-secret-at-least-32-characters-long

AUTH_GITHUB_ID=your-github-oauth-client-id
AUTH_GITHUB_SECRET=your-github-oauth-client-secret
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

AUTH_ALLOWED_EMAILS=your.email@gmail.com

# Register these exact callback URLs in the OAuth applications:
# http://127.0.0.1:4321/api/auth/callback/github
# http://127.0.0.1:4321/api/auth/callback/google