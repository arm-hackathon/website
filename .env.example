# Use Vercel OIDC in deployed functions when the Blob store is connected to this project.
BLOB_STORE_ID=
VERCEL_OIDC_TOKEN=

# Optional local/development fallback. Do not commit a real token.
BLOB_READ_WRITE_TOKEN=

# GitHub and Google OAuth editor access. The comma-separated email addresses are
# the only users allowed to synchronise or delete shared drafts.
AUTH_URL=https://icarus-theta-five.vercel.app
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_ALLOWED_EMAILS=editor.one@gmail.com,editor.two@gmail.com