# Use Vercel OIDC in deployed functions when the Blob store is connected to this project.
BLOB_STORE_ID=
VERCEL_OIDC_TOKEN=

# Optional local/development fallback. Do not commit a real token.
BLOB_READ_WRITE_TOKEN=

# GitHub OAuth editor access. The comma-separated usernames are the only users
# allowed to synchronise or delete shared drafts.
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_ALLOWED_USERNAMES=github_username_one,github_username_two